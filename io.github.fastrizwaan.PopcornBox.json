{
  "app-id": "io.github.fastrizwaan.PopcornBox",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "popcorn-box",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-run/tmp:rw",
    "--socket=pulseaudio",
    "--talk-name=org.freedesktop.ScreenSaver",
    "--talk-name=org.gnome.SessionManager"
  ],
  "modules": [
    {
      "name": "python3-libtorrent",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app libtorrent"
      ],
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      }
    },
    {
      "name": "yt-dlp",
      "no-autogen": true,
      "no-make-install": true,
      "make-args": [
        "yt-dlp",
        "PYTHON=/usr/bin/python3"
      ],
      "post-install": [
        "install -D yt-dlp /app/bin/yt-dlp"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/yt-dlp/yt-dlp/releases/download/2026.03.17/yt-dlp.tar.gz",
          "sha256": "c74f56fc88a7f9b7c995646f30538974a03dd7609f55257b20594fdeeb1e13df",
          "x-checker-data": {
            "is-important": true,
            "type": "json",
            "url": "https://api.github.com/repos/yt-dlp/yt-dlp/releases/latest",
            "version-query": ".tag_name",
            "url-query": ".assets[] | select(.name==\"yt-dlp.tar.gz\") | .browser_download_url"
          }
        }
      ]
    },
    {
      "name": "libass",
      "cleanup": [
        "/include",
        "/lib/pkgconfig"
      ],
      "config-opts": [
        "--disable-static",
        "--enable-asm",
        "--enable-harfbuzz",
        "--enable-fontconfig"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/libass/libass.git",
          "tag": "0.17.4",
          "commit": "bbb3c7f1570a4a021e52683f3fbdf74fe492ae84",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^(\\d\\.\\d{1,3}\\.\\d{1,2})$"
          }
        }
      ]
    },
    {
      "name": "x264",
      "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/man"
      ],
      "config-opts": [
        "--disable-cli",
        "--enable-shared"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/mirror/x264.git",
          "x-checker-data": {
            "type": "json",
            "url": "https://code.videolan.org/api/v4/projects/536/repository/branches/stable",
            "commit-query": ".commit.id",
            "version-query": ".commit.short_id",
            "timestamp-query": ".commit.created_at"
          },
          "branch": "master"
        }
      ]
    },
    {
      "name": "x265",
      "buildsystem": "cmake",
      "subdir": "source",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_STATIC=0",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
      ],
      "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/man"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://bitbucket.org/multicoreware/x265_git.git",
          "tag": "4.1",
          "commit": "1d117bed4747758b51bd2c124d738527e30392cb",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^([\\d.]+)$"
          }
        },
        {
          "type": "patch",
          "path": "patches/x265-cmake_policy.patch"
        }
      ]
    },
    {
      "name": "ffmpeg",
      "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/ffmpeg/examples"
      ],
      "config-opts": [
        "--disable-debug",
        "--disable-doc",
        "--disable-static",
        "--enable-gnutls",
        "--enable-gpl",
        "--enable-shared",
        "--enable-version3",
        "--enable-libass",
        "--enable-libx264",
        "--enable-libx265",
        "--enable-libdrm",
        "--enable-vaapi"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/FFmpeg/FFmpeg.git",
          "commit": "9047fa1b084f76b1b4d065af2d743df1b40dfb56",
          "tag": "n8.1",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^n([\\d.]{3,7})$"
          }
        }
      ]
    },
    {
      "name": "libplacebo",
      "buildsystem": "simple",
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      },
      "build-commands": [
        "meson setup _build --prefix=/app --libdir=lib -Dbuildtype=release -Dvulkan=disabled -Dshaderc=disabled -Dglslang=disabled -Ddemos=false",
        "meson compile -C _build",
        "meson install -C _build"
      ],
      "cleanup": [
        "/include",
        "/lib/pkgconfig"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/haasn/libplacebo.git",
          "tag": "v7.360.1",
          "commit": "cee9b076f2c63104ccfd497fa79c39a867293ec4"
        }
      ]
    },
    {
      "name": "libXpresent",
      "buildsystem": "autotools",
      "sources": [
        {
          "type": "archive",
          "url": "https://xorg.freedesktop.org/archive/individual/lib/libXpresent-1.0.2.tar.xz",
          "sha256": "4e5b21b4812206a4b223013606ae31170502c1043038777a1ef8f70c09d37602",
          "x-checker-data": {
            "type": "anitya",
            "project-id": 16901,
            "url-template": "https://xorg.freedesktop.org/archive/individual/lib/libXpresent-$version.tar.xz"
          }
        }
      ]
    },
    {
      "name": "luajit",
      "no-autogen": true,
      "cleanup": [
        "/bin",
        "/include",
        "/lib/pkgconfig",
        "/share/man"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/LuaJIT/LuaJIT.git",
          "disable-shallow-clone": true,
          "commit": "659a61693aa3b87661864ad0f12eee14c865cd7f",
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/LuaJIT/LuaJIT/branches/v2.1",
            "commit-query": ".commit.sha",
            "version-query": ".commit.sha",
            "timestamp-query": ".commit.commit.committer.date"
          }
        },
        {
          "type": "shell",
          "commands": [
            "sed -i 's|/usr/local|/app|' ./Makefile"
          ]
        }
      ]
    },
    {
      "name": "mpv",
      "buildsystem": "meson",
      "config-opts": [
        "-Dalsa=enabled",
        "-Dbuild-date=false",
        "-Dcplayer=true",
        "-Ddrm=disabled",
        "-Degl-drm=disabled",
        "-Degl-wayland=enabled",
        "-Degl-x11=enabled",
        "-Degl=enabled",
        "-Dgbm=disabled",
        "-Dgl-x11=enabled",
        "-Dgl=enabled",
        "-Diconv=enabled",
        "-Dlibmpv=true",
        "-Dpulse=enabled",
        "-Duchardet=disabled",
        "-Dvaapi-drm=disabled",
        "-Dvaapi-wayland=enabled",
        "-Dvaapi-x11=enabled",
        "-Dvaapi=enabled",
        "-Dvapoursynth=disabled",
        "-Dvdpau-gl-x11=enabled",
        "-Dvdpau=enabled",
        "-Dvulkan=disabled",
        "-Dwayland=enabled",
        "-Dwerror=false",
        "-Dx11=enabled",
        "-Dxv=enabled",
        "-Dzimg=disabled",
        "-Dzlib=enabled",
        "-Dlibarchive=disabled",
        "-Dlcms2=disabled",
        "-Djpeg=disabled",
        "-Drubberband=disabled",
        "-Ddvdnav=disabled",
        "-Dcdda=disabled",
        "-Dlibbluray=disabled"
      ],
      "post-install": [
        "mv /app/bin/mpv /app/bin/mpv-bin",
        "mkdir -p /app/etc/mpv",
        "echo \"screenshot-directory=~/.var/app/io.github.fastrizwaan.PopcornBox/Pictures/mpv\" > /app/etc/mpv/mpv.conf",
        "echo \"ytdl-format=22/bestvideo[vcodec^=avc1]+bestaudio/best\" >> /app/etc/mpv/mpv.conf",
        "echo \"vo=gpu\" >> /app/etc/mpv/mpv.conf",
        "echo \"hwdec=auto\" >> /app/etc/mpv/mpv.conf",
        "echo \"force-window=immediate\" >> /app/etc/mpv/mpv.conf",
        "echo \"fs=yes\" >> /app/etc/mpv/mpv.conf",
        "echo \"subs-fallback=yes\" >> /app/etc/mpv/mpv.conf"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/mpv-player/mpv.git",
          "tag": "v0.41.0",
          "commit": "41f6a645068483470267271e1d09966ca3b9f413",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^v([\\d.]+)$",
            "is-main-source": true
          }
        }
      ]
    },
    {
      "name": "mpv-wrapper",
      "buildsystem": "simple",
      "build-commands": [
        "install -D mpv /app/bin/mpv"
      ],
      "sources": [
        {
          "type": "file",
          "path": "mpv"
        }
      ]
    },
    {
      "name": "mpv_inhibit_gnome",
      "buildsystem": "simple",
      "build-commands": [
        "make",
        "install -D lib/mpv_inhibit_gnome.so /app/etc/mpv/scripts/mpv_inhibit_gnome.so"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/Guldoman/mpv_inhibit_gnome.git",
          "tag": "v0.1.3",
          "commit": "9069be0f15fa2c222d78a183d4aa1477d8a8f2cd",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^v([\\d.]+)$"
          }
        }
      ]
    },
    {
      "name": "python3-mpv",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app python-mpv"
      ],
      "build-options": {
        "build-args": [
          "--share=network"
        ]
      }
    },
    {
      "name": "popcorn-box",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}